    <string name="tc4_settings_title">تنظیمات</string>
    <string name="tc4_settings_description">تنظیمات برنامه را اینجا پیکربندی کنید!\nبرای تنظیمات خاص کانتینر، به \"ویژگی‌ها\" یا \"میانبرها - گزینه‌ها\" مراجعه کنید.</string>

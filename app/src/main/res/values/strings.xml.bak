    <!-- ==================== Container Management ==================== -->
    <string name="tc4_container_title">Container Management</string>
    <string name="tc4_container_empty_hint">No containers, tap top-right to import</string>
    <string name="tc4_container_calculating_space">Calculating usage…</string>
    <string name="tc4_container_delete_success">Deleted successfully</string>
    <string name="tc4_container_delete_failed">Delete failed: %1$s</string>
    <string name="tc4_container_loading_failed">"%1$s" failed to load</string>
    <string name="tc4_container_list_load_failed">Failed to load container list: %1$s</string>
    <string name="tc4_container_config_missing">Container config not found</string>
    <string name="tc4_container_missing_boot_cmd">Container "%1$s" missing boot_command config</string>
    <string name="tc4_container_config_lost">Container "%1$s" config lost, please reinstall</string>

    <!-- Delete dialog -->
    <string name="tc4_dialog_delete_title">Confirm Delete</string>
    <string name="tc4_dialog_delete_message">Are you sure you want to permanently delete "%1$s"?\nThis action cannot be undone.</string>
    <string name="tc4_dialog_deleting_title">Deleting container files, please wait…</string>

    <!-- Edit dialog -->
    <string name="tc4_dialog_edit_container_title">Edit Container Info</string>

    <!-- Exit dialog -->
    <string name="tc4_dialog_exit_title">Exit Container</string>
    <string name="tc4_dialog_exit_message">Do you want to stop the container and return to the management page?</string>

    <!-- ==================== Import Flow ==================== -->
    <string name="tc4_import_title">Import Container</string>
    <string name="tc4_import_warning">1. Only import containers from trusted sources.\nA malicious container can destroy other containers and even the app itself.\nIf you grant storage permission, it can also modify, send, or delete important data on your device (e.g. photos).\n\n2. Disclaimer: This software is open source under GPL, provided WITHOUT ANY WARRANTY.\nThe author assumes no liability under any circumstances.\nUsers must review the source code and assume all risks.</string>
    <string name="tc4_import_builtin_btn">Install Built-in Container</string>
    <string name="tc4_import_copying_title">Copying container files to cache…</string>
    <string name="tc4_import_extracting_title">Extracting configuration…</string>
    <string name="tc4_import_installing_title">Installing container…</string>
    <string name="tc4_import_deleting_old_title">Deleting old container files…</string>
    <string name="tc4_import_cleaning_title">Cleaning temporary files…</string>
    <string name="tc4_import_completed">"%1$s" installed successfully</string>
    <string name="tc4_import_failed">Installation failed: %1$s</string>
    <string name="tc4_import_builtin_failed">Failed to install built-in container: %1$s</string>
    <string name="tc4_import_auto_failed">Auto-install built-in container failed: %1$s</string>
    <string name="tc4_install_state_error">Installation state error, please retry</string>
    <string name="tc4_import_missing_code">Missing \'code\' field in config</string>
    <string name="tc4_import_missing_code_builtin">Missing \'code\' field in built-in container config</string>
    <string name="tc4_import_no_config">.tiny.yaml config not found in container file</string>
    <string name="tc4_import_config_parse_failed">Config parsing failed: %1$s</string>
    <string name="tc4_import_completed_title">Installation Complete</string>
    <string name="tc4_import_failed_title">Installation Failed</string>

    <!-- Install confirm dialog -->
    <string name="tc4_install_launch_after">Launch after install</string>
    <string name="tc4_install_warning_data">Contents of %1$s will be wiped, this action cannot be undone</string>
    <string name="tc4_install_warning_overwrite">"%1$s" is already installed, will be overwritten and cannot be recovered</string>

    <!-- ==================== Export Flow ==================== -->
    <string name="tc4_export_title">Export Container</string>
    <string name="tc4_export_warning">1. The "export" command is provided by the container creator.\nUsually export is not a backup — it generates a shareable container and may include commands to clean private data.\nLinux is flexible and the export result may differ from expectations.\nPlease review export_command in /.tiny.yaml first.\n\n2. Disclaimer: This software is open source under GPL, provided WITHOUT ANY WARRANTY.\nThe author assumes no liability under any circumstances.\nUsers must review the source code and assume all risks.</string>
    <string name="tc4_export_success">Export successful</string>
    <string name="tc4_export_failed">Export failed: %1$s</string>
    <string name="tc4_export_missing_cmd">Missing export_command in config</string>
    <string name="tc4_export_no_output">Export did not produce a file</string>
    <string name="tc4_export_cannot_write">Cannot write to selected path</string>
    <string name="tc4_export_progress_title">Exporting container files…</string>

    <!-- ==================== Settings Page ==================== -->
    <string name="tc4_settings_title">Settings</string>
    <string name="tc4_settings_description">Configure app settings here!\nFor container-specific settings, see "Features" or "Shortcuts - Options".</string>
    <string name="tc4_settings_shortcut_title">Launcher Shortcut Generator</string>
    <string name="tc4_settings_shortcut_desc">Create a desktop shortcut for the current container to run commands directly</string>
    <string name="tc4_settings_auto_launch_title">Auto-launch Container</string>
    <string name="tc4_settings_auto_launch_desc">Takes effect on next container launch</string>
    <string name="tc4_settings_auto_launch_gui_title">Auto-launch GUI</string>
    <string name="tc4_settings_legacy_proot_title">Use Legacy Proot</string>
    <string name="tc4_settings_legacy_proot_desc">The latest proot brings exciting bwrap and netlink emulation.\nIt improves compatibility, but also slows down loading in some scenarios (e.g. network video playback becomes laggy).\n*This setting is global. For per-container settings, change the proot binary in /.tiny.yaml\'s boot command to proot-classic or proot-latest.\nTakes effect on next container launch</string>
    <string name="tc4_settings_reset_bootstrap_title">Reinstall Bootstrap</string>
    <string name="tc4_settings_reset_bootstrap_desc">Takes effect on next container launch</string>
    <string name="tc4_settings_auto_check_update_title">Auto Check for Updates</string>
    <string name="tc4_settings_auto_check_update_desc">Check for new versions when launching a container</string>
    <string name="tc4_settings_manage_files_title">All Files Access</string>
    <string name="tc4_settings_manage_files_desc">Allow the container to access Android files\nWhen using official containers, Android storage is usually at /mnt/sdcard</string>
    <string name="tc4_settings_battery_title">Battery Unrestricted</string>
    <string name="tc4_settings_battery_desc">Disable battery optimization to prevent the app from being killed by the system</string>

    <!-- ==================== Help Page ==================== -->
    <string name="tc4_help_source_code_title">Source Code Repository</string>
    <string name="tc4_help_source_code_desc">See every line of code. Get docs, give feedback and more.</string>
    <string name="tc4_help_releases_title">Release Page</string>
    <string name="tc4_help_releases_desc">Get the latest version of Tiny Container</string>
    <string name="tc4_help_oss_title">Open Source Libraries</string>
    <string name="tc4_help_oss_desc">Thanks to these libraries for making development simpler.</string>
    <string name="tc4_help_license_title">License</string>
    <string name="tc4_help_license_desc">PRoot — an essential component for running Linux — is licensed under GPL, so I have to open source my code too :D</string>
    <string name="tc4_help_wechat_title">WeChat Official Account: 装机宝典</string>
    <string name="tc4_help_wechat_desc">I may post some Tiny Container tutorials here. If you cannot access GitHub, this might help.</string>
    <string name="tc4_help_bilibili_title">Caten\'s Bilibili</string>
    <string name="tc4_help_bilibili_desc">I may post videos about Tiny Container, and also other stuff, like Plants vs. Zombies :P</string>
    <string name="tc4_help_spark_store_title">Link: Spark App Store</string>
    <string name="tc4_help_spark_store_desc">A single spark can start a prairie fire</string>
    <string name="tc4_help_gxde_title">Link: GXDE OS</string>
    <string name="tc4_help_gxde_desc">A Linux distro that is beautiful, light weight and out-of-the-box\nWe bring back DDE 15 with an updated basis on GXDE</string>


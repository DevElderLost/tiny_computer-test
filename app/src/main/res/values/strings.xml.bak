    <!-- ==================== Signal 9 Page ==================== -->
    <string name="tc4_signal9_title">What happened?</string>
    <string name="tc4_signal9_description">Terminal terminated abnormally with error code 9. This is caused by Android 12+ limiting child processes. You need to manually disable this limit.</string>
    <string name="tc4_signal9_tool_hint">You can use these tools to fix:</string>
    <string name="tc4_signal9_tool_btn">Fix Tool</string>
    <string name="tc4_signal9_tutorial_hint">If the above tools don\'t work, or your device is a non-AOSP HarmonyOS device, follow this tutorial (requires PC and USB cable):</string>
    <string name="tc4_signal9_tutorial_btn">Tutorial Link</string>
    <string name="tc4_signal9_dev_options_note">Enable Developer Options in Settings (usually find About Device → tap Build Number 7 times), then find "Disable child process restrictions" in Developer Options and turn it on. Steps may vary by device — search online for specifics.</string>


    <string name="tc4_settings_title">设置</string>
    <string name="tc4_settings_description">这里可以进行软件相关设置！\n针对特定容器的设置见"功能"或"快捷方式-选项"。</string>
    <string name="tc4_settings_shortcut_title">启动器捷径生成器</string>

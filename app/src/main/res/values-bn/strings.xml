    <!-- ==================== Import Flow ==================== -->
    <string name="tc4_import_title">কন্টেইনার ইম্পোর্ট</string>
    <string name="tc4_import_warning">১. শুধুমাত্র বিশ্বস্ত উৎস থেকে কন্টেইনার ইম্পোর্ট করুন।\nএকটি ক্ষতিকারক কন্টেইনার অন্যান্য কন্টেইনার এবং অ্যাপ নিজেই ধ্বংস করতে পারে।\nযদি আপনি স্টোরেজ অনুমতি দেন, এটি আপনার ডিভাইসের গুরুত্বপূর্ণ ডেটা (যেমন ফটো) পরিবর্তন, প্রেরণ বা মুছতে পারে।\n\n২. দায়িত্ব অস্বীকার: এই সফটওয়্যার GPL এর অধীনে ওপেন সোর্স, কোনো ওয়ারেন্টি ছাড়াই প্রদত্ত।\nলেখক কোনো অবস্থাতেই কোনো দায় বহন করেন না।\nব্যবহারকারীদের সোর্স কোড পর্যালোচনা করতে হবে এবং সমস্ত ঝুঁকি গ্রহণ করতে হবে।</string>

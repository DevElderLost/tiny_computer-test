    <string name="tc4_settings_auto_launch_title">স্বয়ংক্রিয়ভাবে কন্টেইনার চালু</string>
    <string name="tc4_settings_auto_launch_desc">পরবর্তী কন্টেইনার লঞ্চে কার্যকর হবে</string>
    <string name="tc4_settings_auto_launch_gui_title">স্বয়ংক্রিয়ভাবে GUI চালু</string>
    <string name="tc4_settings_legacy_proot_title">লিগ্যাসি Proot ব্যবহার করুন</string>
    <string name="tc4_settings_legacy_proot_desc">সর্বশেষ proot উত্তেজনাপূর্ণ bwrap এবং netlink এমুলেশন নিয়ে আসে।\nএটি সামঞ্জস্য উন্নত করে, কিন্তু কিছু পরিস্থিতিতে লোডিং ধীর করে (যেমন নেটওয়ার্ক ভিডিও প্লেব্যাক ধীর হয়ে যায়)।\n*এই সেটিংটি গ্লোবাল। প্রতি-কন্টেইনার সেটিংসের জন্য, /.tiny.yaml এর বুট কমান্ডে proot বাইনারি proot-classic বা proot-latest এ পরিবর্তন করুন।\nপরবর্তী কন্টেইনার লঞ্চে কার্যকর হবে</string>
    <string name="tc4_settings_reset_bootstrap_title">Bootstrap পুনরায় ইনস্টল করুন</string>
    <string name="tc4_settings_reset_bootstrap_desc">পরবর্তী কন্টেইনার লঞ্চে কার্যকর হবে</string>
    <string name="tc4_settings_auto_check_update_title">স্বয়ংক্রিয় আপডেট পরীক্ষা</string>
    <string name="tc4_settings_auto_check_update_desc">কন্টেইনার চালু করার সময় নতুন সংস্করণ পরীক্ষা করুন</string>
    <string name="tc4_settings_manage_files_title">সমস্ত ফাইল অ্যাক্সেস</string>
    <string name="tc4_settings_manage_files_desc">কন্টেইনারকে অ্যান্ড্রয়েড ফাইল অ্যাক্সেস করার অনুমতি দিন\nঅফিসিয়াল কন্টেইনার ব্যবহার করলে, অ্যান্ড্রয়েড স্টোরেজ সাধারণত /mnt/sdcard-এ থাকে</string>
    <string name="tc4_settings_battery_title">ব্যাটারি সীমাহীন</string>

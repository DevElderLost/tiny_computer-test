    <!-- ==================== Export Flow ==================== -->
    <string name="tc4_export_title">কন্টেইনার রপ্তানি</string>
    <string name="tc4_export_warning">১. \"রপ্তানি\" কমান্ড কন্টেইনার নির্মাতা প্রদান করেন।\nসাধারণত রপ্তানি ব্যাকআপ নয় — এটি একটি শেয়ারযোগ্য কন্টেইনার তৈরি করে এবং ব্যক্তিগত ডেটা পরিষ্কারের কমান্ড অন্তর্ভুক্ত করতে পারে।\nলিনাক্স নমনীয় এবং রপ্তানি ফলাফল প্রত্যাশা থেকে ভিন্ন হতে পারে।\nদয়া করে প্রথমে /.tiny.yaml এ export_command পর্যালোচনা করুন।\n\n২. দায়িত্ব অস্বীকার: এই সফটওয়্যার GPL এর অধীনে ওপেন সোর্স, কোনো ওয়ারেন্টি ছাড়াই প্রদত্ত।\nলেখক কোনো অবস্থাতেই কোনো দায় বহন করেন না।\nব্যবহারকারীদের সোর্স কোড পর্যালোচনা করতে হবে এবং সমস্ত ঝুঁকি গ্রহণ করতে হবে।</string>

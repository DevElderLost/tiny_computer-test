    <string name="tc4_settings_title">सेटिंग्स</string>
    <string name="tc4_settings_description">यहाँ ऐप सेटिंग्स कॉन्फ़िगर करें!\nकंटेनर-विशिष्ट सेटिंग्स के लिए, \"सुविधाएँ\" या \"शॉर्टकट - विकल्प\" देखें।</string>
    <string name="tc4_settings_shortcut_title">लॉन्चर शॉर्टकट जनरेटर</string>
    <string name="tc4_settings_shortcut_desc">सीधे कमांड चलाने के लिए वर्तमान कंटेनर का डेस्कटॉप शॉर्टकट बनाएँ</string>
    <string name="tc4_settings_auto_launch_title">कंटेनर स्वतः लॉन्च करें</string>
    <string name="tc4_settings_auto_launch_desc">अगले कंटेनर लॉन्च पर प्रभावी होगा</string>
    <string name="tc4_settings_auto_launch_gui_title">GUI स्वतः लॉन्च करें</string>
    <string name="tc4_settings_legacy_proot_title">लीगेसी Proot का उपयोग करें</string>
    <string name="tc4_settings_legacy_proot_desc">नवीनतम proot रोमांचक bwrap और netlink एमुलेशन लाता है।\nयह संगतता में सुधार करता है, लेकिन कुछ परिदृश्यों में लोडिंग धीमी कर देता है (जैसे नेटवर्क वीडियो प्लेबैक धीमा हो जाता है)।\n*यह सेटिंग वैश्विक है। प्रति-कंटेनर सेटिंग्स के लिए, /.tiny.yaml के बूट कमांड में proot बाइनरी को proot-classic या proot-latest में बदलें।\nअगले कंटेनर लॉन्च पर प्रभावी होगा</string>
    <string name="tc4_settings_reset_bootstrap_title">Bootstrap पुनः इंस्टॉल करें</string>
    <string name="tc4_settings_reset_bootstrap_desc">अगले कंटेनर लॉन्च पर प्रभावी होगा</string>
    <string name="tc4_settings_auto_check_update_title">स्वचालित अद्यतन जाँच</string>
    <string name="tc4_settings_auto_check_update_desc">कंटेनर लॉन्च करते समय नए संस्करणों की जाँच करें</string>
    <string name="tc4_settings_manage_files_title">सभी फ़ाइलों तक पहुँच</string>
    <string name="tc4_settings_manage_files_desc">कंटेनर को Android फ़ाइलों तक पहुँचने की अनुमति दें\nआधिकारिक कंटेनरों का उपयोग करते समय, Android संग्रहण आमतौर पर /mnt/sdcard पर होता है</string>
    <string name="tc4_settings_battery_title">बैटरी असीमित</string>
    <string name="tc4_settings_battery_desc">ऐप को सिस्टम द्वारा मारे जाने से रोकने के लिए बैटरी ऑप्टिमाइज़ेशन अक्षम करें</string>

    <string name="tc4_help_source_code_title">स्रोत कोड रिपॉज़िटरी</string>
    <string name="tc4_help_source_code_desc">कोड की हर पंक्ति देखें। दस्तावेज़ प्राप्त करें, प्रतिक्रिया दें और अधिक।</string>
    <string name="tc4_help_releases_title">रिलीज़ पृष्ठ</string>
    <string name="tc4_help_releases_desc">Tiny Container का नवीनतम संस्करण प्राप्त करें</string>
    <string name="tc4_help_oss_title">ओपन सोर्स लाइब्रेरीज़</string>
    <string name="tc4_help_oss_desc">विकास को सरल बनाने के लिए इन लाइब्रेरीज़ का धन्यवाद।</string>
    <string name="tc4_help_license_title">लाइसेंस</string>
    <string name="tc4_help_license_desc">PRoot — लिनक्स चलाने के लिए एक आवश्यक घटक — GPL के तहत लाइसेंस प्राप्त है, इसलिए मुझे भी अपना कोड ओपन सोर्स करना होगा :D</string>
    <string name="tc4_help_wechat_title">WeChat आधिकारिक खाता: 装机宝典</string>
    <string name="tc4_help_wechat_desc">मैं यहाँ कुछ Tiny Container ट्यूटोरियल पोस्ट कर सकता हूँ। यदि आप GitHub तक नहीं पहुँच सकते, तो यह मदद कर सकता है।</string>
    <string name="tc4_help_bilibili_title">Caten का Bilibili</string>
    <string name="tc4_help_bilibili_desc">मैं Tiny Container के बारे में वीडियो पोस्ट कर सकता हूँ, और अन्य चीज़ें भी, जैसे Plants vs. Zombies :P</string>
    <string name="tc4_help_spark_store_title">लिंक: Spark App Store</string>
    <string name="tc4_help_spark_store_desc">एक चिंगारी प्रेयरी में आग लगा सकती है</string>
    <string name="tc4_help_gxde_title">लिंक: GXDE OS</string>
    <string name="tc4_help_gxde_desc">सुंदर, हल्का, उपयोग के लिए तैयार लिनक्स वितरण।\nअपडेटेड बेस पर निर्मित, GXDE DDE 15 को फिर से सुर्खियों में लाता है</string>


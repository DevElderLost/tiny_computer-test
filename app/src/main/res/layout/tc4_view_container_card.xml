<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="24dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardMaxElevation="0dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:strokeWidth="2dp"
    app:strokeColor="?attr/colorSecondary"
    app:contentPadding="16dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 正常内容 -->
        <LinearLayout
            android:id="@+id/normal_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/buttons"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="?android:attr/textAppearanceLarge"
                        android:id="@+id/name"
                        tools:text="Container Name"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/buttons"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <Button
                        android:id="@+id/delete"
                        style="?attr/materialIconButtonStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:tooltipText="@string/tc4_quicks_cd_delete"
                        android:textColor="?attr/colorError"
                        app:icon="@drawable/delete_forever_24dp_1f1f1f_fill0_wght400_grad0_opsz24"
                        app:iconTint="?attr/colorError" />
                    <Button
                        android:id="@+id/export"
                        style="?attr/materialIconButtonStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:tooltipText="@string/tc4_tooltip_export"
                        app:icon="@drawable/upload_24dp_1f1f1f_fill0_wght400_grad0_opsz24" />
                    <Button
                        android:id="@+id/edit"
                        style="?attr/materialIconButtonStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:tooltipText="@string/tc4_quicks_cd_edit"
                        app:icon="@drawable/edit_24dp_eaddff_fill0_wght400_grad0_opsz24" />
                    <Button
                        android:id="@+id/launch"
                        style="?attr/materialIconButtonStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:tooltipText="@string/tc4_tooltip_launch"
                        app:icon="@drawable/play_arrow_24dp_1f1f1f_fill0_wght400_grad0_opsz24" />

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingTop="8dp"
                android:scrollbars="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/image"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter" />
                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="8dp"/>
                    <TextView
                        android:id="@+id/description"
                        android:autoLink="web"
                        android:linksClickable="true"
                        tools:text="Container Description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>
            </ScrollView>
            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:layout_marginVertical="8dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center">
                <TextView
                    android:id="@+id/space"
                    tools:text="Calculating usage…"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

        <!-- 单容器错误覆盖 -->
        <LinearLayout
            android:id="@+id/card_error_group"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/card_error_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:gravity="center"
                android:paddingBottom="24dp"
                tools:text="加载失败" />

            <Button
                android:id="@+id/card_error_delete_btn"
                style="?attr/materialIconButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:tooltipText="@string/tc4_quicks_cd_delete"
                app:icon="@drawable/delete_forever_24dp_1f1f1f_fill0_wght400_grad0_opsz24"
                app:iconTint="?attr/colorError" />
        </LinearLayout>

    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
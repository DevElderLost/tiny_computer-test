<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.page.ContainerManageFragment">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewpager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/indicator" />

    <com.zhpan.indicator.IndicatorView
        android:id="@+id/indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:translationY="-12dp"
        app:vpi_slider_radius="2dp"
        app:vpi_slide_mode="worm"
        app:vpi_style="circle"
        app:vpi_slider_checked_color="?attr/colorOnSurface"
        app:vpi_slider_normal_color="?attr/colorControlNormal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- ========== 空列表提示 ========== -->
    <TextView
        android:id="@+id/empty_hint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        android:autoLink="web"
        android:linksClickable="true"
        android:text="@string/tc4_container_empty_with_link"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ========== 加载中覆盖层 ========== -->
    <LinearLayout
        android:id="@+id/loading_group"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.Material3Expressive.CircularProgressIndicator.Wavy"
            android:indeterminate="true"
            app:indicatorSize="52dp"
            app:trackCornerRadius="4dp"
            app:trackThickness="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/tc4_container_loading"
            android:textAppearance="?attr/textAppearanceBodyMedium" />
    </LinearLayout>

    <!-- ========== 错误覆盖层（整个列表加载失败） ========== -->
    <LinearLayout
        android:id="@+id/error_group"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/error_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:paddingBottom="24dp"
            tools:text="加载容器列表失败" />

        <Button
            android:id="@+id/error_delete_btn"
            style="?attr/materialIconButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:tooltipText="@string/tc4_tooltip_remove_error"
            app:icon="@drawable/delete_forever_24dp_1f1f1f_fill0_wght400_grad0_opsz24"
            app:iconTint="?attr/colorError" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
